LEX Program

%{
#include<stdio.h>
%}

/* Definitions */

letter      [a-zA-Z]
digit       [0-9]

%%

/* Valid Variable */

{letter}({letter}|{digit})*
{
    printf("VALID VARIABLE : %s\n", yytext);
}

/* Invalid Variable Starting with Digit */

{digit}({letter}|{digit})*
{
    printf("INVALID VARIABLE : %s\n", yytext);
}

/* Ignore Spaces and New Lines */

[ \t\n]+    ;

/* Other Characters */

.
{
    printf("INVALID INPUT : %s\n", yytext);
}

%%

int main()
{
    printf("Enter variable names:\n");

    yylex();

    return 0;
}

int yywrap()
{
    return 1;
}


YACC Program


%{
#include<stdio.h>
#include<stdlib.h>

void yyerror(char *s);
int yylex();
%}

%token VALID INVALID

%%

start:
        VALID '\n'
        {
            printf("Valid Variable\n");
        }

      | INVALID '\n'
        {
            printf("Invalid Variable\n");
        }
      ;

%%

void yyerror(char *s)
{
    printf("Syntax Error\n");
}

int main()
{
    printf("Enter Variable Name:\n");

    yyparse();

    return 0;
}





Step 1: Generate YACC File
yacc -d var.y
Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex var.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o var
If error occurs:
gcc lex.yy.c y.tab.c -o var -lfl


Step 4: Run
./var
