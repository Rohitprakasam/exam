YACC Program

Save as:
type.y





%{
#include<stdio.h>
#include<stdlib.h>
#include<string.h>

void yyerror(char *s);
int yylex();

/* Symbol Table */

struct symtab
{
    char name[20];
    char type[10];
};

struct symtab table[100];

int count = 0;

/* Insert Symbol */

void insert(char name[], char type[])
{
    strcpy(table[count].name, name);
    strcpy(table[count].type, type);

    count++;
}

/* Get Type */

char* gettype(char name[])
{
    int i;

    for(i=0; i<count; i++)
    {
        if(strcmp(table[i].name, name) == 0)
        {
            return table[i].type;
        }
    }

    return "undefined";
}
%}

/* Union */

%union
{
    char str[20];
}

/* Tokens */

%token INT FLOAT CHAR
%token NUM FNUM
%token <str> ID

/* Types */

%type <str> datatype expr

%%

program:
            declarations statements
            ;

declarations:
              declarations declaration
            |
            ;

declaration:
              datatype ID ';'
              {
                    insert($2, $1);
              }
              ;

datatype:
            INT
            {
                strcpy($$, "int");
            }

          | FLOAT
            {
                strcpy($$, "float");
            }

          | CHAR
            {
                strcpy($$, "char");
            }
            ;

statements:
            statements statement
          |
          ;

statement:
            ID '=' expr ';'
            {
                char *idtype = gettype($1);

                if(strcmp(idtype, $3) == 0)
                {
                    printf("Type Correct\n");
                }
                else
                {
                    printf("Type Mismatch Error\n");
                }
            }
            ;

expr:
        NUM
        {
            strcpy($$, "int");
        }

      | FNUM
        {
            strcpy($$, "float");
        }

      | ID
        {
            strcpy($$, gettype($1));
        }
      ;

%%

void yyerror(char *s)
{
    printf("Syntax Error\n");
}

int main()
{
    printf("Enter Program:\n");

    yyparse();

    return 0;
}


Steps to Execute in Cygwin64

Step 1: Generate YACC File
yacc -d type.y

Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex type.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o typecheck
If error occurs:
gcc lex.yy.c y.tab.c -o typecheck -lfl

Step 4: Run
./typecheck





