{
    strcpy(yylval.str, yytext);
    return ID;
}

[0-9]+"."[0-9]+
{
    return FNUM;
}

[0-9]+
{
    return NUM;
}

';'         return ';';
','         return ',';
'='         return '=';

[ \t\n]     ;

