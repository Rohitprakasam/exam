LEX Program

%{
#include "y.tab.h"
#include<stdio.h>
%}

%%

"if"            return IF;
"else"          return ELSE;
"while"         return WHILE;
"for"           return FOR;
"switch"        return SWITCH;
"case"          return CASE;
"default"       return DEFAULT;
"break"         return BREAK;

"("             return '(';
")"             return ')';
"{"             return '{';
"}"             return '}';
";"             return ';';
":"             return ':';

[0-9]+          return NUM;

[a-zA-Z_][a-zA-Z0-9_]*   return ID;

"=="|"<"|">"|"<="|">="|"!="|"="|"+"|"-"|"*"|"/"
                return OP;

[ \t\n]         ;

.               return yytext[0];

%%

int yywrap()
{
    return 1;
}




YACC Program


%{
#include<stdio.h>
#include<stdlib.h>

void yyerror(char *s);
int yylex();
%}

%token IF ELSE WHILE FOR SWITCH CASE DEFAULT BREAK
%token ID NUM OP

%%

start:
        statement
        {
            printf("Valid Control Structure\n");
        }
        ;

statement:

          if_stmt

        | while_stmt

        | for_stmt

        | switch_stmt
        ;

/* IF ELSE */

if_stmt:
          IF '(' condition ')' block

        | IF '(' condition ')' block ELSE block

        | IF '(' condition ')' block ELSE if_stmt
        ;

/* WHILE */

while_stmt:
            WHILE '(' condition ')' block
            ;

/* FOR */

for_stmt:
          FOR '(' expr ';' condition ';' expr ')' block
          ;

/* SWITCH CASE */

switch_stmt:
            SWITCH '(' ID ')' '{' case_list default_stmt '}'
            ;

case_list:
            case_list case_stmt
          |
          ;

case_stmt:
            CASE NUM ':' block BREAK ';'
            ;

default_stmt:
            DEFAULT ':' block
          |
          ;

/* CONDITION */

condition:
            ID OP ID
          | ID OP NUM
          | NUM OP NUM
          ;

/* EXPRESSION */

expr:
        ID '=' NUM
      | ID '=' ID
      | ID OP OP
      |
      ;

/* BLOCK */

block:
        '{' '}'
      | '{' statement '}'
      ;

%%

void yyerror(char *s)
{
    printf("Invalid Control Structure\n");
}

int main()
{
    printf("Enter Control Structure:\n");

    yyparse();

    return 0;
}




Steps to Execute in Cygwin64
Step 1: Generate YACC File
yacc -d control.y
Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex control.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o control
If error occurs:
gcc lex.yy.c y.tab.c -o control -lfl

Step 4: Run
./control



