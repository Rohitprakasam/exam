YACC Program


%{
#include<stdio.h>
#include<stdlib.h>

void yyerror(char *s);
int yylex();
%}

%token NUMBER

%left '+' '-'
%left '*' '/'
%left '(' ')'

%%

input:
        | input line
        ;

line:
        '\n'
        | exp '\n'   { printf("Result = %d\n", $1); }
        ;

exp:
        NUMBER              { $$ = $1; }

        | exp '+' exp       { $$ = $1 + $3; }

        | exp '-' exp       { $$ = $1 - $3; }

        | exp '*' exp       { $$ = $1 * $3; }

        | exp '/' exp
            {
                if($3 == 0)
                {
                    printf("Division by zero error\n");
                    $$ = 0;
                }
                else
                    $$ = $1 / $3;
            }

        | '(' exp ')'       { $$ = $2; }
        ;

%%

void yyerror(char *s)
{
    printf("Invalid Expression\n");
}

int main()
{
    printf("Enter Arithmetic Expression:\n");
    yyparse();
    return 0;
}







Steps to Execute in Cygwin64
Step 1: Generate YACC File
yacc -d expr.y

Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex expr.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o expr
If error occurs:
gcc lex.yy.c y.tab.c -o expr -lfl

Step 4: Run
./expr
