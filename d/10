%{
#include<stdio.h>
#include<string.h>
%}

/* Definitions */

digit      [0-9]
letter     [a-zA-Z]
id         {letter}({letter}|{digit})*
number     {digit}+

%%

/* Keywords */

"int"|"float"|"char"|"if"|"else"|"while"|"return"
{
    printf("KEYWORD : %s\n", yytext);
}

/* Identifiers */

{id}
{
    printf("IDENTIFIER : %s\n", yytext);
}

/* Constants */

{number}
{
    printf("CONSTANT : %s\n", yytext);
}

/* Operators */

"+"|"-"|"*"|"/"|"="|"=="|"<"|">"
{
    printf("OPERATOR : %s\n", yytext);
}

/* Special Symbols */

";"|","|"("|")"|"{"|"}"
{
    printf("SPECIAL SYMBOL : %s\n", yytext);
}

/* Ignore Spaces */

[ \t\n]+   ;

/* Invalid Characters */

.
{
    printf("INVALID CHARACTER : %s\n", yytext);
}

%%

int main()
{
    printf("Enter the C program:\n");

    yylex();

    return 0;
}

int yywrap()
{
    return 1;
}






Steps to Execute in Cygwin64
Step 1: Save the file
Save the program as:
lexer.l

Step 2: Generate C file using FLEX
flex lexer.l
This generates:
lex.yy.c

Step 3: Compile the program
gcc lex.yy.c -o lexer
If needed:
gcc lex.yy.c -o lexer -lfl

Step 4: Run the program
./lexer











