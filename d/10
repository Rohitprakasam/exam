Experiment — Disk Scheduling using SSTF

Aim
To implement SSTF (Shortest Seek Time First) Disk Scheduling Algorithm.


Algorithm
Read disk request sequence.
Read initial head position.
Find nearest request to current head.
Move head to nearest request.
Mark request as completed.
Repeat until all requests are serviced.
Calculate total seek time.


Program

#include <stdio.h>
#include <stdlib.h>

int main()
{
    int req[50], visited[50];
    int n, head, i, j;
    int total = 0;

    printf("Enter number of disk requests: ");
    scanf("%d", &n);

    printf("Enter disk request sequence:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &req[i]);
        visited[i] = 0;
    }

    printf("Enter initial head position: ");
    scanf("%d", &head);

    printf("\nSeek Sequence:\n");

    for(i = 0; i < n; i++)
    {
        int min = 9999;
        int index = -1;

        for(j = 0; j < n; j++)
        {
            if(visited[j] == 0)
            {
                int dist = abs(req[j] - head);

                if(dist < min)
                {
                    min = dist;
                    index = j;
                }
            }
        }

        visited[index] = 1;

        printf("%d -> ", req[index]);

        total += abs(req[index] - head);

        head = req[index];
    }

    printf("\n\nTotal Seek Time = %d\n", total);

    return 0;
}



Compile and Run
gcc sstf.c
./a.out


