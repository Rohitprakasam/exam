YACC Program
Save as:
opt.y


%{
#include<stdio.h>
#include<stdlib.h>
#include<string.h>

void yyerror(char *s);
int yylex();

int isNumber(char str[])
{
    int i;

    for(i=0; str[i] != '\0'; i++)
    {
        if(str[i] < '0' || str[i] > '9')
            return 0;
    }

    return 1;
}
%}

/* Union */

%union
{
    char str[50];
}

/* Tokens */

%token <str> ID NUM

/* Types */

%type <str> expr

%%

stmt:
        ID '=' expr '\n'
        {
            printf("\nOptimized Code:\n");

            printf("%s = %s\n", $1, $3);
        }
        ;

expr:

      expr '+' expr
      {
            /* Algebraic Transformation */

            if(strcmp($1,"0")==0)
                strcpy($$, $3);

            else if(strcmp($3,"0")==0)
                strcpy($$, $1);

            /* Constant Folding */

            else if(isNumber($1) && isNumber($3))
            {
                sprintf($$, "%d", atoi($1)+atoi($3));
            }

            else
            {
                sprintf($$, "%s + %s", $1, $3);
            }
      }

    | expr '-' expr
      {
            /* Algebraic Transformation */

            if(strcmp($3,"0")==0)
                strcpy($$, $1);

            /* Constant Folding */

            else if(isNumber($1) && isNumber($3))
            {
                sprintf($$, "%d", atoi($1)-atoi($3));
            }

            else
            {
                sprintf($$, "%s - %s", $1, $3);
            }
      }

    | expr '*' expr
      {
            /* Algebraic Transformation */

            if(strcmp($1,"1")==0)
                strcpy($$, $3);

            else if(strcmp($3,"1")==0)
                strcpy($$, $1);

            else if(strcmp($1,"0")==0 || strcmp($3,"0")==0)
                strcpy($$, "0");

            /* Strength Reduction */

            else if(strcmp($3,"2")==0)
            {
                sprintf($$, "%s + %s", $1, $1);
            }

            /* Constant Folding */

            else if(isNumber($1) && isNumber($3))
            {
                sprintf($$, "%d", atoi($1)*atoi($3));
            }

            else
            {
                sprintf($$, "%s * %s", $1, $3);
            }
      }

    | expr '/' expr
      {
            /* Algebraic Transformation */

            if(strcmp($3,"1")==0)
                strcpy($$, $1);

            /* Constant Folding */

            else if(isNumber($1) && isNumber($3))
            {
                sprintf($$, "%d", atoi($1)/atoi($3));
            }

            else
            {
                sprintf($$, "%s / %s", $1, $3);
            }
      }

    | '(' expr ')'
      {
            strcpy($$, $2);
      }

    | ID
      {
            strcpy($$, $1);
      }

    | NUM
      {
            strcpy($$, $1);
      }
      ;

%%

void yyerror(char *s)
{
    printf("Invalid Expression\n");
}

int main()
{
    printf("Enter Expression:\n");

    yyparse();

    return 0;
}




