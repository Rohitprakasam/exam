Experiment — Memory Allocation (First Fit, Best Fit, Worst Fit)

Aim
To implement First Fit, Best Fit and Worst Fit memory allocation techniques.

Algorithm
Read memory block sizes and process sizes.
In First Fit:
Allocate first sufficient block.
In Best Fit:
Allocate smallest suitable block.
In Worst Fit:
Allocate largest suitable block.
Display allocation results.



Program:

#include <stdio.h>

int main()
{
    int b[20], p[20], nb, np;
    int i, j;

    printf("Enter number of memory blocks: ");
    scanf("%d", &nb);

    printf("Enter number of processes: ");
    scanf("%d", &np);

    printf("Enter block sizes:\n");

    for(i = 0; i < nb; i++)
    {
        scanf("%d", &b[i]);
    }

    printf("Enter process sizes:\n");

    for(i = 0; i < np; i++)
    {
        scanf("%d", &p[i]);
    }

    printf("\n----- FIRST FIT -----\n");

    int temp1[20];

    for(i = 0; i < nb; i++)
        temp1[i] = b[i];

    for(i = 0; i < np; i++)
    {
        for(j = 0; j < nb; j++)
        {
            if(temp1[j] >= p[i])
            {
                printf("Process %d allocated to Block %d\n",
                       i + 1, j + 1);

                temp1[j] -= p[i];
                break;
            }
        }

        if(j == nb)
            printf("Process %d not allocated\n", i + 1);
    }

    printf("\n----- BEST FIT -----\n");

    int temp2[20];

    for(i = 0; i < nb; i++)
        temp2[i] = b[i];

    for(i = 0; i < np; i++)
    {
        int best = -1;

        for(j = 0; j < nb; j++)
        {
            if(temp2[j] >= p[i])
            {
                if(best == -1 || temp2[j] < temp2[best])
                    best = j;
            }
        }

        if(best != -1)
        {
            printf("Process %d allocated to Block %d\n",
                   i + 1, best + 1);

            temp2[best] -= p[i];
        }
        else
        {
            printf("Process %d not allocated\n", i + 1);
        }
    }

    printf("\n----- WORST FIT -----\n");

    int temp3[20];

    for(i = 0; i < nb; i++)
        temp3[i] = b[i];

    for(i = 0; i < np; i++)
    {
        int worst = -1;

        for(j = 0; j < nb; j++)
        {
            if(temp3[j] >= p[i])
            {
                if(worst == -1 || temp3[j] > temp3[worst])
                    worst = j;
            }
        }

        if(worst != -1)
        {
            printf("Process %d allocated to Block %d\n",
                   i + 1, worst + 1);

            temp3[worst] -= p[i];
        }
        else
        {
            printf("Process %d not allocated\n", i + 1);
        }
    }

    return 0;
}



