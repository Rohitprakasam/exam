YACC Program


%{
#include<stdio.h>
#include<stdlib.h>

int yylex();
void yyerror(char *s);
%}

%token NUMBER

%left '+' '-'
%left '*' '/'

%%

input:
        | input line
        ;

line:
        '\n'

      | expr '\n'
        {
            printf("Result = %d\n", $1);
        }
        ;

expr:
        NUMBER
        {
            $$ = $1;
        }

      | expr '+' expr
        {
            $$ = $1 + $3;
        }

      | expr '-' expr
        {
            $$ = $1 - $3;
        }

      | expr '*' expr
        {
            $$ = $1 * $3;
        }

      | expr '/' expr
        {
            if($3 == 0)
            {
                printf("Division by zero error\n");
                $$ = 0;
            }
            else
            {
                $$ = $1 / $3;
            }
        }

      | '(' expr ')'
        {
            $$ = $2;
        }
        ;

%%

void yyerror(char *s)
{
    printf("Invalid Expression\n");
}

int main()
{
    printf("Enter Arithmetic Expression:\n");

    yyparse();

    return 0;
}







Steps to Execute in Cygwin64

Step 1: Generate YACC File
yacc -d calc.y
Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex calc.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o calc
If error occurs:
gcc lex.yy.c y.tab.c -o calc -lfl

Step 4: Run
./calc




