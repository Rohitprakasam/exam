Implement Back-End of Compiler using LEX and YACC
(Three Address Code to 8086 Assembly Code)

Aim
To implement the back-end of a compiler that converts Three Address Code (TAC) into 8086 Assembly Language code using LEX and YACC.


LEX Program
Save as:
backend.l

LEX Program

%{
#include "y.tab.h"
#include <string.h>
%}
%%
[a-zA-Z_][a-zA-Z0-9_]* { strcpy(yylval.name, yytext); return ID; }
[0-9]+                  { strcpy(yylval.name, yytext); return NUM; }
"="  return '=';
"+"  return '+';
"-"  return '-';
"*"  return '*';
"/"  return '/';
\n   return '\n';
[ \t]+ ;
%%

YACC Program

YACC Program (backend.y)
%{
#include <stdio.h>
#include <string.h>
int yylex();
void yyerror(const char *s);
%}
%union {
    char name[20];
}
%token <name> ID NUM
%%
program : program stmt
        | stmt
        ;
stmt : ID '=' ID '+' ID '\n'
       {
           printf("MOV AX, %s\n", $3);
           printf("ADD AX, %s\n", $5);
           printf("MOV %s, AX\n\n", $1);
       }
     | ID '=' ID '-' ID '\n'
       {
           printf("MOV AX, %s\n", $3);
           printf("SUB AX, %s\n", $5);
           printf("MOV %s, AX\n\n", $1);
       }
     | ID '=' ID '*' ID '\n'
       {
           printf("MOV AX, %s\n", $3);
           printf("MOV BX, %s\n", $5);
           printf("MUL BX\n");
           printf("MOV %s, AX\n\n", $1);
       }
     | ID '=' ID '/' ID '\n'
       {
           printf("MOV AX, %s\n", $3);
           printf("MOV BX, %s\n", $5);
           printf("DIV BX\n");
           printf("MOV %s, AX\n\n", $1);
       }
     | ID '=' ID '\n'
       {
           printf("MOV AX, %s\n", $3);
           printf("MOV %s, AX\n\n", $1);
       }
     ;
%%
void yyerror(const char *s) {
    printf("Invalid TAC Statement\n");
}
int main() {
    printf("Enter Three Address Code:\n\n");
    yyparse();
    return 0;
}






Steps to Execute in Cygwin64

Step 1: Generate YACC File
yacc -d backend.y
Generated files:
y.tab.c
y.tab.h

Step 2: Generate LEX File
flex backend.l
Generated file:
lex.yy.c

Step 3: Compile
gcc lex.yy.c y.tab.c -o backend
If error occurs:
gcc lex.yy.c y.tab.c -o backend -lfl

Step 4: Run
./backend



Sample Input 1
a=b+c

Output
MOV AX, b
ADD AX, c
MOV AX, AX
MOV a, AX


Sample Input 2
x=y-z

Output
MOV AX, y
SUB AX, z
MOV AX, AX
MOV x, AX
